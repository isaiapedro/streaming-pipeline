{
  "__inputs": [
    {
      "name": "DS_INFLUXDB_CLOUD",
      "label": "InfluxDB Cloud",
      "description": "InfluxDB Cloud datasource (Flux)",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana",   "id": "grafana",        "name": "Grafana",        "version": "10.0.0" },
    { "type": "datasource","id": "influxdb",        "name": "InfluxDB",       "version": "1.0.0"  },
    { "type": "panel",     "id": "state-timeline",  "name": "State timeline", "version": ""       },
    { "type": "panel",     "id": "timeseries",      "name": "Time series",    "version": ""       }
  ],
  "uid": "patient-vitals-mvp",
  "title": "Patient Vitals Monitoring",
  "description": "Real-time vitals for 6 patients — MVP pipeline (NATS → Brain → InfluxDB Cloud)",
  "tags": ["medical", "realtime", "tcc"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,

  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "constant",
        "query": "vitals",
        "current": { "value": "vitals", "text": "vitals" },
        "hide": 2
      }
    ]
  },

  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },

  "panels": [
    {
      "id": 1,
      "type": "state-timeline",
      "title": "Alarm Level — All Patients × Signals",
      "description": "Shows ok / warning / critical per (patient, signal) over time. Sourced from the alarm_level tag written by the Brain service.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_CLOUD}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> map(fn: (r) => ({\n      _time:  r._time,\n      _value: if r.alarm_level == \"critical\" then 2\n              else if r.alarm_level == \"warning\" then 1\n              else 0,\n      _field: r.patient_id + \" / \" + r.signal_type\n    }))\n  |> group(columns: [\"_field\"])\n  |> sort(columns: [\"_time\"])"
        }
      ],
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "red",    "value": 2    }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK",       "color": "green",  "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "WARNING",  "color": "yellow", "index": 1 } } },
            { "type": "value", "options": { "2": { "text": "CRITICAL", "color": "red",    "index": 2 } } }
          ]
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Heart Rate (bpm)",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_CLOUD}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\")\n  |> filter(fn: (r) => r.signal_type == \"heart_rate\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"patient_id\", \"condition\"])\n  |> sort(columns: [\"_time\"])"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bpm",
          "color": { "mode": "palette-classic" },
          "custom": {
            "thresholdsStyle": { "mode": "line" },
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 50   },
              { "color": "green",  "value": 60   },
              { "color": "yellow", "value": 100  },
              { "color": "red",    "value": 120  }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "SpO2 (%)",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_CLOUD}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\")\n  |> filter(fn: (r) => r.signal_type == \"spo2\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"patient_id\", \"condition\"])\n  |> sort(columns: [\"_time\"])"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 80,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "thresholdsStyle": { "mode": "line" },
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 90   },
              { "color": "green",  "value": 94   }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Blood Pressure — Systolic (mmHg)",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_CLOUD}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\")\n  |> filter(fn: (r) => r.signal_type == \"systolic_bp\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"patient_id\", \"condition\"])\n  |> sort(columns: [\"_time\"])"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mmHg",
          "color": { "mode": "palette-classic" },
          "custom": {
            "thresholdsStyle": { "mode": "line" },
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green",  "value": 90   },
              { "color": "yellow", "value": 140  },
              { "color": "red",    "value": 180  }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Respiratory Rate (breaths/min)",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_CLOUD}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\")\n  |> filter(fn: (r) => r.signal_type == \"respiratory_rate\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"patient_id\", \"condition\"])\n  |> sort(columns: [\"_time\"])"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "breaths/min",
          "color": { "mode": "palette-classic" },
          "custom": {
            "thresholdsStyle": { "mode": "line" },
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green",  "value": 10   },
              { "color": "yellow", "value": 20   },
              { "color": "red",    "value": 30   }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Temperature (°C)",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_CLOUD}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\")\n  |> filter(fn: (r) => r.signal_type == \"temperature\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"patient_id\", \"condition\"])\n  |> sort(columns: [\"_time\"])"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "custom": {
            "thresholdsStyle": { "mode": "line" },
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null  },
              { "color": "green",  "value": 36.0  },
              { "color": "yellow", "value": 37.5  },
              { "color": "red",    "value": 38.5  }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
